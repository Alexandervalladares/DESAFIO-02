<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".VentaExpressApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VentaExpress">
        <activity
            android:name=".ui.sales.SaleFormActivity"
            android:parentActivityName=".ui.sales.SalesActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="com.example.ventaexpress.ui.sales.SalesActivity" />
        </activity>
        <activity
            android:name=".ui.sales.SalesActivity"
            android:parentActivityName=".MainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="com.example.ventaexpress.MainActivity" />
        </activity>
        <activity
            android:name=".ui.clients.ClientFormActivity"
            android:parentActivityName=".ui.clients.ClientsActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="com.example.ventaexpress.ui.clients.ClientsActivity" />
        </activity>
        <activity
            android:name=".ui.clients.ClientsActivity"
            android:parentActivityName=".MainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="com.example.ventaexpress.MainActivity" />
        </activity>
        <activity
            android:name=".ui.products.ProductFormActivity"
            android:parentActivityName=".ui.products.ProductsActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="com.example.ventaexpress.ui.products.ProductsActivity" />
        </activity>
        <activity
            android:name=".ui.products.ProductsActivity"
            android:parentActivityName=".MainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="com.example.ventaexpress.MainActivity" />
        </activity>
        <activity android:name=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
